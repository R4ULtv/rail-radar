{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["VERCEL_TARGET_ENV"],
  "remoteCache": {
    "enabled": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "web#build": {
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["MAPBOX_SERVER_TOKEN"]
    },
    "studio#build": {
      "outputs": [".svelte-kit/**", "!.svelte-kit/cache/**"],
      "env": ["PUBLIC_POSTHOG_KEY", "PUBLIC_STUDIO_LOCAL_MODE", "LOCAL_ENV", "STUDIO_LOCAL_MODE"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
