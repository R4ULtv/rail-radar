CLOUDFLARE_ACCOUNT_ID="" # Cloudflare Account ID used for Analytics Engine queries
CLOUDFLARE_API_TOKEN="" # Cloudflare API Token with Analytics Engine read access
IP_HASH_PEPPER="" # Random secret used to key the visitor-IP HMAC (generate 32+ random bytes; rotating it resets unique-visitor continuity)
MAPBOX_TOKEN="" # Mapbox token used by the /map/static endpoint
NS_API_KEY="" # Get Api-Key from NS Portal (Netherlands)
LDBWS_API_KEY="" # National Rail LDBWS API key (United Kingdom)
TRAFIKLAB_KEY="" # Trafiklab API key (Sweden)
REJSEPLANEN_API_KEY="" # Rejseplanen API key (Denmark)
PLK_API_KEY="" # PDP API key (Poland)
SNCF_API_KEY="" # SNCF API key (France)
