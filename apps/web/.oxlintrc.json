{
  "extends": ["../../.oxlintrc.json"],
  "plugins": ["react", "nextjs"],
  "settings": {
    "next": {
      "rootDir": "."
    }
  },
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts"],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
